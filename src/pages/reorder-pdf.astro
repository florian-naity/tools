---
import BaseLayout from '../layouts/BaseLayout.astro';
import DropZone from '../components/DropZone.astro';
import ThumbnailGrid from '../components/ThumbnailGrid.astro';
---

<BaseLayout title="Reorder & Delete PDF Pages — Free Online Editor" description="Drag and drop to reorder or remove pages from a PDF, then save the result. Free and runs entirely in your browser — no upload required.">

  <!-- ─── Header ───────────────────────────────────────── -->
  <div class="mb-10 animate-fade-in-up">
    <a href="/" class="back-link">All Tools</a>
    <div class="mt-4 flex items-start gap-4">
      <div class="shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center text-2xl bg-orange-500/10 border border-orange-500/25 shadow-lg shadow-orange-500/5">
        ✂️
      </div>
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-orange-400 mb-1">PDF Tools</p>
        <h1 class="text-2xl font-bold leading-tight">Reorder & Delete Pages</h1>
        <p class="text-sm text-base-content/55 mt-1 max-w-md">
          Drag pages into the order you want, remove the ones you don't need, then download the cleaned-up PDF. Your files never leave your device.
        </p>
      </div>
    </div>
  </div>

  <div class="flex flex-col gap-6">

    <div class="animate-fade-in-up" style="animation-delay: 80ms;">
      <div class="relative rounded-2xl border border-orange-500/20 bg-base-200 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-orange-500/5 via-transparent to-transparent pointer-events-none"></div>
        <div class="relative p-5">
          <DropZone id="pdf-input" accept="application/pdf" multiple={false} label="Click to upload a PDF or drag & drop" />
        </div>
      </div>
    </div>

    <div id="editor" class="hidden flex flex-col gap-4 animate-fade-in-up" style="animation-delay: 120ms;">
      <p class="text-xs font-bold uppercase tracking-widest text-base-content/30">Pages</p>
      <div class="flex items-center justify-between flex-wrap gap-2 px-1">
        <p id="page-count" class="text-sm text-base-content/50"></p>
        <div class="flex gap-2">
          <button id="reset-btn" class="btn btn-ghost btn-xs text-base-content/40">Reset</button>
          <button id="generate-btn" class="btn btn-primary btn-sm">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 4v11"/>
            </svg>
            Download PDF
          </button>
        </div>
      </div>

      <div id="loading-row" class="hidden flex items-center gap-3 text-sm text-base-content/50 px-1">
        <span class="loading loading-spinner loading-sm text-orange-400"></span>
        <span id="loading-label">Rendering thumbnails…</span>
      </div>

      <div class="rounded-xl border border-orange-500/15 bg-base-200/50 p-3">
        <ThumbnailGrid id="page-grid" />
      </div>

      <p id="gen-status" class="text-sm text-base-content/50 text-center hidden"></p>
    </div>

  </div>

  <div class="mt-10 pt-6 border-t border-base-300 flex flex-col sm:flex-row items-center justify-between gap-2">
    <p class="text-xs text-base-content/30">Your files never leave your device.</p>
    <p class="text-xs text-base-content/25">Powered by <a href="https://mozilla.github.io/pdf.js/" class="underline hover:text-primary transition-colors" target="_blank" rel="noopener">PDF.js</a> (Apache 2.0) · <a href="https://github.com/Hopding/pdf-lib" class="underline hover:text-primary transition-colors" target="_blank" rel="noopener">pdf-lib</a> (MIT).</p>
  </div>
  <!-- ─── How it works + FAQ ──────────────────────────────── -->
  <div class="mt-16 flex flex-col gap-10 border-t border-base-300 pt-10">

    <section>
      <p class="text-xs font-bold uppercase tracking-widest text-orange-400 mb-5">How it works</p>
      <ol class="flex flex-col gap-4">
        <li class="flex gap-3 items-start">
          <span class="shrink-0 w-6 h-6 rounded-full bg-orange-500/15 border border-orange-500/25 text-xs font-bold text-orange-400 flex items-center justify-center mt-0.5">1</span>
          <p class="text-sm text-base-content/70 leading-relaxed">Upload your PDF using the drop zone or drag & drop.</p>
        </li>
        <li class="flex gap-3 items-start">
          <span class="shrink-0 w-6 h-6 rounded-full bg-orange-500/15 border border-orange-500/25 text-xs font-bold text-orange-400 flex items-center justify-center mt-0.5">2</span>
          <p class="text-sm text-base-content/70 leading-relaxed">Drag page thumbnails into the order you want, or click ✕ to delete pages you don't need.</p>
        </li>
        <li class="flex gap-3 items-start">
          <span class="shrink-0 w-6 h-6 rounded-full bg-orange-500/15 border border-orange-500/25 text-xs font-bold text-orange-400 flex items-center justify-center mt-0.5">3</span>
          <p class="text-sm text-base-content/70 leading-relaxed">Click "Download PDF" to save the updated file to your device.</p>
        </li>
      </ol>
    </section>

    <section>
      <p class="text-xs font-bold uppercase tracking-widest text-orange-400 mb-4">Frequently asked questions</p>
      <div class="flex flex-col divide-y divide-base-300">
        <details class="py-4 group">
          <summary class="cursor-pointer list-none text-sm font-semibold text-base-content/80 flex justify-between items-center gap-4">
            Can I delete pages as well as reorder them?
            <span class="group-open:rotate-180 transition-transform shrink-0 text-base-content/30 text-xs">▾</span>
          </summary>
          <p class="mt-3 text-sm text-base-content/55 leading-relaxed">Yes — click the remove button (✕) on any thumbnail to delete that page before downloading.</p>
        </details>
        <details class="py-4 group">
          <summary class="cursor-pointer list-none text-sm font-semibold text-base-content/80 flex justify-between items-center gap-4">
            Will the PDF quality be affected?
            <span class="group-open:rotate-180 transition-transform shrink-0 text-base-content/30 text-xs">▾</span>
          </summary>
          <p class="mt-3 text-sm text-base-content/55 leading-relaxed">No — pages are copied directly without re-encoding, so the original quality is fully preserved.</p>
        </details>
        <details class="py-4 group">
          <summary class="cursor-pointer list-none text-sm font-semibold text-base-content/80 flex justify-between items-center gap-4">
            Do my files get sent to a server?
            <span class="group-open:rotate-180 transition-transform shrink-0 text-base-content/30 text-xs">▾</span>
          </summary>
          <p class="mt-3 text-sm text-base-content/55 leading-relaxed">No. All processing happens locally in your browser using PDF.js and pdf-lib. Your files never leave your device.</p>
        </details>
        <details class="py-4 group">
          <summary class="cursor-pointer list-none text-sm font-semibold text-base-content/80 flex justify-between items-center gap-4">
            Is there a page limit?
            <span class="group-open:rotate-180 transition-transform shrink-0 text-base-content/30 text-xs">▾</span>
          </summary>
          <p class="mt-3 text-sm text-base-content/55 leading-relaxed">No hard limit. Rendering thumbnails for very large PDFs may take a moment depending on your device.</p>
        </details>
      </div>
    </section>

  </div>

  <script is:inline type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Can I delete pages as well as reorder them?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — click the remove button on any thumbnail to delete that page before downloading." } },
      { "@type": "Question", "name": "Will the PDF quality be affected?", "acceptedAnswer": { "@type": "Answer", "text": "No — pages are copied directly without re-encoding, so the original quality is fully preserved." } },
      { "@type": "Question", "name": "Do my files get sent to a server?", "acceptedAnswer": { "@type": "Answer", "text": "No. All processing happens locally in your browser. Your files never leave your device." } },
      { "@type": "Question", "name": "Is there a page limit?", "acceptedAnswer": { "@type": "Answer", "text": "No hard limit. Rendering thumbnails for very large PDFs may take a moment depending on your device." } }
    ]
  }</script>

</BaseLayout>

<script>
  import * as pdfjsLib from 'pdfjs-dist';
  import { PDFDocument } from 'pdf-lib';

  pdfjsLib.GlobalWorkerOptions.workerSrc = '/vendor/pdf.worker.min.js';

  const editor = document.getElementById('editor') as HTMLDivElement;
  const pageCount = document.getElementById('page-count') as HTMLParagraphElement;
  const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
  const resetBtn = document.getElementById('reset-btn') as HTMLButtonElement;
  const genStatus = document.getElementById('gen-status') as HTMLParagraphElement;
  const loadingRow = document.getElementById('loading-row') as HTMLDivElement;
  const loadingLabel = document.getElementById('loading-label') as HTMLSpanElement;

  let originalBytes: ArrayBuffer | null = null;
  let originalPdf: pdfjsLib.PDFDocumentProxy | null = null;

  function getGrid() {
    return (window as any).__thumbGrids?.get('page-grid');
  }

  function updateCount() {
    const grid = getGrid();
    const n = grid?.getOrder().length ?? 0;
    pageCount.textContent = `${n} page${n !== 1 ? 's' : ''}`;
  }

  async function loadPdf(bytes: ArrayBuffer) {
    originalBytes = bytes;
    originalPdf = await pdfjsLib.getDocument({ data: bytes.slice(0) }).promise;

    editor.classList.remove('hidden');
    loadingRow.classList.remove('hidden');

    const grid = getGrid();
    grid.clear();

    const total = originalPdf.numPages;
    for (let i = 1; i <= total; i++) {
      loadingLabel.textContent = `Rendering page ${i} of ${total}…`;
      const page = await originalPdf.getPage(i);
      const vp = page.getViewport({ scale: 0.35 });
      const canvas = document.createElement('canvas');
      canvas.width = vp.width; canvas.height = vp.height;
      await page.render({ canvasContext: canvas.getContext('2d')!, canvas, viewport: vp }).promise;
      grid.addItem({ id: `page-${i}`, label: `Page ${i}`, canvas, pageIndex: i - 1 });
    }

    loadingRow.classList.add('hidden');
    updateCount();
  }

  document.addEventListener('dropzone:files', async (e: Event) => {
    const file = (e as CustomEvent<FileList>).detail[0];
    if (!file || file.type !== 'application/pdf') return;
    const bytes = await file.arrayBuffer();
    await loadPdf(bytes);
  });

  document.getElementById('page-grid')!.addEventListener('grid:changed', updateCount);

  resetBtn.addEventListener('click', async () => {
    if (originalBytes) await loadPdf(originalBytes);
  });

  generateBtn.addEventListener('click', async () => {
    if (!originalBytes) return;
    const grid = getGrid();
    const ordered = grid.getOrder();
    if (!ordered.length) return;

    generateBtn.disabled = true;
    genStatus.textContent = 'Building PDF…';
    genStatus.classList.remove('hidden');

    try {
      const srcDoc = await PDFDocument.load(originalBytes);
      const newDoc = await PDFDocument.create();
      const pageIndices = ordered.map((item: any) => item.pageIndex as number);
      const copied = await newDoc.copyPages(srcDoc, pageIndices);
      copied.forEach(p => newDoc.addPage(p));

      const pdfBytes = await newDoc.save();
      const blob = new Blob([pdfBytes.buffer as ArrayBuffer], { type: 'application/pdf' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url; a.download = 'reordered.pdf'; a.click();
      URL.revokeObjectURL(url);

      genStatus.textContent = `Done — ${ordered.length} page${ordered.length !== 1 ? 's' : ''}.`;
    } catch (err) {
      genStatus.textContent = 'Error: ' + (err as Error).message;
    } finally {
      generateBtn.disabled = false;
    }
  });
</script>
