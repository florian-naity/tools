---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="QR Code Generator"
  description="Generate a customized QR code from any text or URL. Runs entirely in your browser."
>
  <!-- ─── Header ───────────────────────────────────────── -->
  <div class="mb-10 animate-fade-in-up">
    <a href="/" class="back-link">All Tools</a>
    <div class="mt-4 flex items-start gap-4">
      <div class="shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center text-2xl bg-primary/10 border border-primary/25 shadow-lg shadow-primary/5">
        ⬛
      </div>
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-primary mb-1">QR Code</p>
        <h1 class="text-2xl font-bold leading-tight">QR Code Generator</h1>
        <p class="text-sm text-base-content/55 mt-1 max-w-md">
          Paste any text or URL, pick a style, and your QR code updates instantly. Your files never leave your device.
        </p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <!-- ─── Options panel ─────────────────────────────── -->
    <div class="order-2 md:order-1 animate-fade-in-up" style="animation-delay: 80ms;">
      <p class="text-xs font-bold uppercase tracking-widest text-base-content/30 mb-3">Options</p>
      <div class="relative rounded-2xl bg-base-200 border border-primary/20 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-transparent pointer-events-none"></div>
        <div class="relative p-6 flex flex-col gap-5">

          <!-- Text / URL -->
          <div class="flex flex-col gap-2">
            <label class="text-xs font-semibold uppercase tracking-widest text-primary/60">Text or URL</label>
            <textarea
              id="qr-input"
              class="textarea textarea-bordered bg-base-100 border-base-300 focus:border-primary resize-none h-24 text-sm"
              placeholder="https://example.com"
            ></textarea>
          </div>

          <!-- Dot style — visual swatches -->
          <div class="flex flex-col gap-2">
            <label class="text-xs font-semibold uppercase tracking-widest text-primary/60">Dot Style</label>
            <div class="grid grid-cols-4 gap-2">
              {([
                ['square',        'Square',        'M0 0h6v6H0zM7.5 0H13.5V6H7.5zM15 0h6v6H15zM0 7.5h6v6H0zM7.5 7.5H13.5V13.5H7.5zM15 7.5h6v6H15zM0 15h6v6H0zM7.5 15H13.5V21H7.5zM15 15h6v6H15z'],
                ['rounded',       'Rounded',       null],
                ['dots',          'Dots',          null],
                ['extra-rounded', 'Soft',          null],
              ] as [string, string, string | null][]).map(([value, label], i) => (
                <label class="dot-swatch-label flex flex-col items-center gap-1.5 p-2.5 rounded-xl border border-base-300 cursor-pointer transition-all hover:border-primary/40 has-[:checked]:border-primary has-[:checked]:bg-primary/10">
                  <input type="radio" name="dot-style" value={value} class="hidden" checked={i === 0} />
                  <svg viewBox="0 0 21 21" fill="currentColor" class="w-6 h-6 text-base-content/60 has-checked:text-primary" aria-hidden="true">
                    {value === 'square' && <path d="M0 0h6v6H0zM7.5 0H13.5V6H7.5zM15 0h6v6H15zM0 7.5h6v6H0zM7.5 7.5H13.5V13.5H7.5zM15 7.5h6v6H15zM0 15h6v6H0zM7.5 15H13.5V21H7.5zM15 15h6v6H15z" />}
                    {value === 'rounded' && <><rect x="0" y="0" width="6" height="6" rx="1.5"/><rect x="7.5" y="0" width="6" height="6" rx="1.5"/><rect x="15" y="0" width="6" height="6" rx="1.5"/><rect x="0" y="7.5" width="6" height="6" rx="1.5"/><rect x="7.5" y="7.5" width="6" height="6" rx="1.5"/><rect x="15" y="7.5" width="6" height="6" rx="1.5"/><rect x="0" y="15" width="6" height="6" rx="1.5"/><rect x="7.5" y="15" width="6" height="6" rx="1.5"/><rect x="15" y="15" width="6" height="6" rx="1.5"/></>}
                    {value === 'dots' && <><circle cx="3" cy="3" r="3"/><circle cx="10.5" cy="3" r="3"/><circle cx="18" cy="3" r="3"/><circle cx="3" cy="10.5" r="3"/><circle cx="10.5" cy="10.5" r="3"/><circle cx="18" cy="10.5" r="3"/><circle cx="3" cy="18" r="3"/><circle cx="10.5" cy="18" r="3"/><circle cx="18" cy="18" r="3"/></>}
                    {value === 'extra-rounded' && <><rect x="0" y="0" width="6" height="6" rx="3"/><rect x="7.5" y="0" width="6" height="6" rx="3"/><rect x="15" y="0" width="6" height="6" rx="3"/><rect x="0" y="7.5" width="6" height="6" rx="3"/><rect x="7.5" y="7.5" width="6" height="6" rx="3"/><rect x="15" y="7.5" width="6" height="6" rx="3"/><rect x="0" y="15" width="6" height="6" rx="3"/><rect x="7.5" y="15" width="6" height="6" rx="3"/><rect x="15" y="15" width="6" height="6" rx="3"/></>}
                  </svg>
                  <span class="text-xs text-base-content/50">{label}</span>
                </label>
              ))}
            </div>
          </div>

          <!-- Dot color (main) -->
          <div class="flex flex-col gap-2">
            <label class="text-xs font-semibold uppercase tracking-widest text-primary/60">Dot Color</label>
            <div class="flex items-center gap-3">
              <input id="dot-color" type="color" value="#1c1917" class="w-10 h-10 rounded-lg cursor-pointer border border-base-300 bg-transparent" />
              <span id="dot-color-label" class="text-xs text-base-content/40 font-mono">#1c1917</span>
            </div>
          </div>

          <!-- Logo upload -->
          <div class="flex flex-col gap-2">
            <label class="text-xs font-semibold uppercase tracking-widest text-primary/60">Center Logo <span class="normal-case font-normal text-base-content/30">(PNG or SVG, optional)</span></label>
            <div class="flex items-center gap-3">
              <label class="btn btn-outline btn-sm cursor-pointer">
                Upload logo
                <input id="logo-input" type="file" accept="image/png,image/svg+xml" class="hidden" />
              </label>
              <span id="logo-name" class="text-xs text-base-content/40">No file selected</span>
              <button id="logo-clear" class="btn btn-ghost btn-xs text-base-content/30 hidden">✕</button>
            </div>
          </div>

          <!-- Advanced toggle -->
          <div>
            <button
              id="advanced-toggle"
              type="button"
              class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-base-content/30 hover:text-base-content/50 transition-colors"
            >
              <svg id="advanced-chevron" class="w-3 h-3 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
              Advanced
            </button>

            <div id="advanced-panel" class="hidden mt-4 flex flex-col gap-5 pt-4 border-t border-base-300/50">

              <!-- Corner colors -->
              <div class="flex flex-col gap-3">
                <div class="flex items-center justify-between">
                  <label class="text-xs font-semibold uppercase tracking-widest text-primary/60">Corner Colors</label>
                  <label class="flex items-center gap-1.5 cursor-pointer">
                    <input id="link-colors" type="checkbox" class="checkbox checkbox-primary checkbox-xs" checked />
                    <span class="text-xs text-base-content/40">Match dot color</span>
                  </label>
                </div>
                <div id="corner-color-wrap" class="flex flex-col gap-2 opacity-40 pointer-events-none">
                  <div class="flex items-center gap-3">
                    <span class="text-xs text-base-content/35 w-12 shrink-0">Outer</span>
                    <input id="corner-square-color" type="color" value="#1c1917" class="w-9 h-9 rounded-lg cursor-pointer border border-base-300 bg-transparent" />
                    <span id="corner-square-color-label" class="text-xs text-base-content/40 font-mono">#1c1917</span>
                  </div>
                  <div class="flex items-center gap-3">
                    <span class="text-xs text-base-content/35 w-12 shrink-0">Inner</span>
                    <input id="corner-dot-color" type="color" value="#1c1917" class="w-9 h-9 rounded-lg cursor-pointer border border-base-300 bg-transparent" />
                    <span id="corner-dot-color-label" class="text-xs text-base-content/40 font-mono">#1c1917</span>
                  </div>
                </div>
              </div>

              <!-- Background color + transparency -->
              <div class="flex flex-col gap-3">
                <div class="flex items-center justify-between">
                  <label class="text-xs font-semibold uppercase tracking-widest text-primary/60">Background</label>
                  <label class="flex items-center gap-1.5 cursor-pointer">
                    <input id="bg-transparent" type="checkbox" class="checkbox checkbox-primary checkbox-xs" />
                    <span class="text-xs text-base-content/40">Transparent</span>
                  </label>
                </div>
                <div id="bg-color-wrap" class="flex items-center gap-3">
                  <input id="bg-color" type="color" value="#fafaf9" class="w-10 h-10 rounded-lg cursor-pointer border border-base-300 bg-transparent" />
                  <span id="bg-color-label" class="text-xs text-base-content/40 font-mono">#fafaf9</span>
                </div>
                <p class="text-xs text-base-content/25 italic">Transparent background only works when downloading as SVG.</p>
              </div>

              <!-- Error correction -->
              <div class="flex flex-col gap-2">
                <label class="text-xs font-semibold uppercase tracking-widest text-primary/60">Redundancy</label>
                <div class="grid grid-cols-2 gap-2">
                  {([
                    ['L', 'Low',    'Smallest code'],
                    ['M', 'Medium', 'Balanced'],
                    ['Q', 'High',   'More robust'],
                    ['H', 'Max',    'Use with logo'],
                  ] as [string, string, string][]).map(([value, name, desc], i) => (
                    <label class="flex flex-col gap-0.5 py-2 px-3 rounded-xl border border-base-300 cursor-pointer transition-all hover:border-primary/40 has-[:checked]:border-primary has-[:checked]:bg-primary/10">
                      <input type="radio" name="ecl" value={value} class="hidden" checked={i === 1} />
                      <span class="text-xs font-semibold text-base-content/70">{name}</span>
                      <span class="text-xs text-base-content/35">{desc}</span>
                    </label>
                  ))}
                </div>
              </div>

            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- ─── Preview panel ─────────────────────────────── -->
    <div class="order-1 md:order-2 animate-fade-in-up" style="animation-delay: 120ms;">
      <p class="text-xs font-bold uppercase tracking-widest text-base-content/30 mb-3">Preview</p>
      <div class="rounded-2xl bg-base-200 border border-primary/20 p-6 flex flex-col items-center justify-center gap-4 min-h-64 md:sticky md:top-24">
        <div id="qr-output" class="hidden flex flex-col items-center gap-4 w-full">
          <div id="qr-canvas-container" class="rounded-lg overflow-hidden"></div>
          <div class="flex gap-2 items-center">
            <!-- PNG download with size picker -->
            <div class="dropdown dropdown-top dropdown-center">
              <button tabindex="0" role="button" class="btn btn-primary btn-sm gap-1.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 4v11"/>
                </svg>
                PNG
                <svg class="w-3 h-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <ul tabindex="0" class="dropdown-content z-10 menu menu-sm bg-base-100 border border-base-300 rounded-xl shadow-xl p-1 w-40 mb-2">
                <li><button class="png-size-btn" data-size="300">Small · 300 px</button></li>
                <li><button class="png-size-btn" data-size="600">Print · 600 px</button></li>
                <li><button class="png-size-btn" data-size="1024">High-res · 1024 px</button></li>
              </ul>
            </div>
            <button id="qr-download-svg" class="btn btn-outline btn-sm">SVG</button>
          </div>
        </div>
        <p id="qr-placeholder" class="text-sm text-base-content/30 text-center">Start typing to generate your QR code.</p>
        <p id="qr-error" class="hidden text-sm text-error text-center"></p>
      </div>
    </div>

  </div>

  <div class="mt-10 pt-6 border-t border-base-300 flex flex-col sm:flex-row items-center justify-between gap-2">
    <p class="text-xs text-base-content/30">Your files never leave your device.</p>
    <p class="text-xs text-base-content/25">Powered by <a href="https://github.com/kozakdenys/qr-code-styling" class="underline hover:text-primary transition-colors" target="_blank" rel="noopener">qr-code-styling</a> (MIT).</p>
  </div>
</BaseLayout>

<script>
  import QRCodeStyling from 'qr-code-styling';

  const input         = document.getElementById('qr-input')            as HTMLTextAreaElement;
  const container     = document.getElementById('qr-canvas-container') as HTMLDivElement;
  const output        = document.getElementById('qr-output')           as HTMLDivElement;
  const placeholder   = document.getElementById('qr-placeholder')      as HTMLParagraphElement;
  const errorEl       = document.getElementById('qr-error')            as HTMLParagraphElement;
  const downloadSvg   = document.getElementById('qr-download-svg')     as HTMLButtonElement;
  const logoInput     = document.getElementById('logo-input')          as HTMLInputElement;
  const logoName      = document.getElementById('logo-name')           as HTMLSpanElement;
  const logoClear     = document.getElementById('logo-clear')          as HTMLButtonElement;
  const dotColorInput   = document.getElementById('dot-color')         as HTMLInputElement;
  const dotColorLabel   = document.getElementById('dot-color-label')   as HTMLSpanElement;
  const cornerSquareColorInput  = document.getElementById('corner-square-color')        as HTMLInputElement;
  const cornerSquareColorLabel  = document.getElementById('corner-square-color-label')  as HTMLSpanElement;
  const cornerDotColorInput     = document.getElementById('corner-dot-color')            as HTMLInputElement;
  const cornerDotColorLabel     = document.getElementById('corner-dot-color-label')      as HTMLSpanElement;
  const cornerColorWrap         = document.getElementById('corner-color-wrap')           as HTMLDivElement;
  const bgColorInput    = document.getElementById('bg-color')          as HTMLInputElement;
  const bgColorLabel    = document.getElementById('bg-color-label')    as HTMLSpanElement;
  const bgColorWrap     = document.getElementById('bg-color-wrap')     as HTMLDivElement;
  const bgTransparent   = document.getElementById('bg-transparent')    as HTMLInputElement;
  const linkColors      = document.getElementById('link-colors')       as HTMLInputElement;
  const advancedToggle  = document.getElementById('advanced-toggle')   as HTMLButtonElement;
  const advancedPanel   = document.getElementById('advanced-panel')    as HTMLDivElement;
  const advancedChevron = document.getElementById('advanced-chevron')  as HTMLElement;

  let logoDataUrl: string | undefined = undefined;
  let qrCode: InstanceType<typeof QRCodeStyling> | null = null;

  // ── Helpers ──────────────────────────────────────────
  function debounce<T extends (...args: any[]) => void>(fn: T, ms: number): T {
    let timer: ReturnType<typeof setTimeout>;
    return ((...args: any[]) => { clearTimeout(timer); timer = setTimeout(() => fn(...args), ms); }) as T;
  }

  function getRadio(name: string): string {
    return (document.querySelector(`input[name="${name}"]:checked`) as HTMLInputElement)?.value ?? '';
  }

  // ── Advanced toggle ───────────────────────────────────
  advancedToggle.addEventListener('click', () => {
    const open = advancedPanel.classList.toggle('hidden');
    advancedChevron.style.transform = open ? '' : 'rotate(90deg)';
  });

  // ── Link colors ──────────────────────────────────────
  function syncCornerColors(color: string) {
    cornerSquareColorInput.value = color;
    cornerSquareColorLabel.textContent = color;
    cornerDotColorInput.value = color;
    cornerDotColorLabel.textContent = color;
  }

  function updateLinkState() {
    const linked = linkColors.checked;
    cornerColorWrap.classList.toggle('opacity-40', linked);
    cornerColorWrap.classList.toggle('pointer-events-none', linked);
    if (linked) syncCornerColors(dotColorInput.value);
  }
  linkColors.addEventListener('change', updateLinkState);

  dotColorInput.addEventListener('input', () => {
    dotColorLabel.textContent = dotColorInput.value;
    if (linkColors.checked) syncCornerColors(dotColorInput.value);
    generate();
  });

  cornerSquareColorInput.addEventListener('input', () => {
    cornerSquareColorLabel.textContent = cornerSquareColorInput.value;
    generate();
  });

  cornerDotColorInput.addEventListener('input', () => {
    cornerDotColorLabel.textContent = cornerDotColorInput.value;
    generate();
  });

  bgColorInput.addEventListener('input', () => {
    bgColorLabel.textContent = bgColorInput.value;
    generate();
  });

  bgTransparent.addEventListener('change', () => {
    const transparent = bgTransparent.checked;
    bgColorWrap.classList.toggle('opacity-40', transparent);
    bgColorWrap.classList.toggle('pointer-events-none', transparent);
    generate();
  });

  // ── Logo handling ─────────────────────────────────────
  logoInput.addEventListener('change', () => {
    const file = logoInput.files?.[0];
    if (!file) return;
    logoName.textContent = file.name;
    logoClear.classList.remove('hidden');
    // Force max ECL when logo is present
    const maxEcl = document.querySelector('input[name="ecl"][value="H"]') as HTMLInputElement;
    if (maxEcl) maxEcl.checked = true;
    const reader = new FileReader();
    reader.onload = (e) => { logoDataUrl = e.target?.result as string; generate(); };
    reader.readAsDataURL(file);
  });

  logoClear.addEventListener('click', () => {
    logoInput.value = '';
    logoDataUrl = undefined;
    logoName.textContent = 'No file selected';
    logoClear.classList.add('hidden');
    generate();
  });

  // ── Build QR config ───────────────────────────────────
  function buildConfig(size: number) {
    const ecl       = getRadio('ecl') as 'L' | 'M' | 'Q' | 'H' || 'M';
    const dotStyle  = getRadio('dot-style') as any || 'square';
    const dotColor         = dotColorInput.value;
    const cornerSquareColor = linkColors.checked ? dotColorInput.value : cornerSquareColorInput.value;
    const cornerDotColor    = linkColors.checked ? dotColorInput.value : cornerDotColorInput.value;
    const bgColor           = bgTransparent.checked ? 'rgba(0,0,0,0)' : bgColorInput.value;
    return {
      width: size, height: size,
      data: input.value.trim(),
      image: logoDataUrl,
      qrOptions: { errorCorrectionLevel: ecl },
      dotsOptions: { type: dotStyle, color: dotColor },
      cornersSquareOptions: { type: (dotStyle === 'square' ? 'square' : 'extra-rounded') as any, color: cornerSquareColor },
      cornersDotOptions:    { type: (dotStyle === 'square' ? 'square' : 'dot') as any,           color: cornerDotColor },
      backgroundOptions: { color: bgColor },
      imageOptions: { crossOrigin: 'anonymous', margin: 6, imageSize: 0.4 },
    };
  }

  // ── Core generate (preview at fixed size) ────────────
  function generate() {
    const text = input.value.trim();
    if (!text) {
      output.classList.add('hidden');
      errorEl.classList.add('hidden');
      placeholder.classList.remove('hidden');
      return;
    }

    container.innerHTML = '';
    qrCode = new QRCodeStyling(buildConfig(300));
    qrCode.append(container);
    output.classList.remove('hidden');
    placeholder.classList.add('hidden');
    errorEl.classList.add('hidden');
  }

  const debouncedGenerate = debounce(generate, 350);

  // ── Wire up all live inputs ───────────────────────────
  input.addEventListener('input', debouncedGenerate);

  document.querySelectorAll('input[name="dot-style"], input[name="ecl"]')
    .forEach(el => el.addEventListener('change', generate));

  // ── Downloads ─────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.png-size-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = input.value.trim();
      if (!text) return;
      const size = parseInt(btn.dataset.size ?? '600');
      new QRCodeStyling(buildConfig(size)).download({ name: 'qrcode', extension: 'png' });
      (btn.closest('.dropdown') as HTMLElement)?.blur();
    });
  });
  downloadSvg.addEventListener('click', () => {
    const text = input.value.trim();
    if (!text) return;
    new QRCodeStyling(buildConfig(600)).download({ name: 'qrcode', extension: 'svg' });
  });

  // ── Init ──────────────────────────────────────────────
  updateLinkState();
</script>
