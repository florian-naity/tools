---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Offline Examiner Tracker"
  description="Track your EPO examiner productivity goal against your real vacation schedule — entirely in Excel, no internet required."
>

  <!-- ─── Header ─────────────────────────────────────── -->
  <div class="mb-10 animate-fade-in-up">
    <a href="/" class="back-link">All Tools</a>

    <div class="flex items-center gap-3 mt-3">
      <span class="text-3xl leading-none">📗</span>
      <div>
        <h1 class="text-2xl font-bold leading-tight">Offline Examiner Tracker</h1>
        <p class="text-sm text-base-content/50 mt-0.5">
          For EPO patent examiners — tracks whether you're on target, accounting for your actual vacation days.
        </p>
      </div>
    </div>
  </div>

  <!-- ─── Download hero card ─────────────────────────── -->
  <div class="animate-fade-in-up" style="animation-delay: 80ms;">
    <div class="relative rounded-2xl border border-violet-500/25 bg-base-200 overflow-hidden">

      <!-- Subtle gradient backdrop -->
      <div class="absolute inset-0 bg-gradient-to-br from-violet-500/5 via-transparent to-transparent pointer-events-none"></div>

      <div class="relative px-8 py-10 flex flex-col sm:flex-row items-center gap-8">

        <!-- Left: text + download -->
        <div class="flex-1 min-w-0 text-center sm:text-left">
          <p class="text-xs font-bold uppercase tracking-widest text-violet-400 mb-2">Excel · No internet required</p>
          <h2 class="text-xl font-bold text-base-content mb-2 leading-snug">
            Download the tracker and open it in Excel
          </h2>
          <p class="text-sm text-base-content/55 mb-7 max-w-sm leading-relaxed">
            Fill in your settings once — vacation days, yearly goal — and the sheet does the rest.
            It recalculates your expected productivity daily, so you always know exactly where you stand.
          </p>

          <a
            href="/documents/EPO%20Pervisional%20Production.xlsx"
            download="EPO Pervisional Production.xlsx"
            class="inline-flex items-center gap-2.5 btn btn-primary btn-lg shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-shadow whitespace-nowrap"
          >
            <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 4v11"/>
            </svg>
            Download Excel Tracker
          </a>

          <p class="mt-3 text-xs text-base-content/30">.xlsx · Microsoft Excel or compatible</p>
        </div>

        <!-- Right: decorative icon block -->
        <div class="hidden sm:flex shrink-0 items-center justify-center w-32 h-32 rounded-2xl bg-base-300/60 border border-base-300 text-6xl select-none">
          📗
        </div>

      </div>
    </div>
  </div>

  <!-- ─── Features row ────────────────────────────────── -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6 animate-fade-in-up" style="animation-delay: 140ms;">

    <div class="rounded-xl bg-base-200 border border-base-300 px-5 py-4">
      <div class="text-xl mb-2">📅</div>
      <p class="text-sm font-semibold text-base-content/80 mb-1">Vacation-aware</p>
      <p class="text-xs text-base-content/45 leading-relaxed">
        Enter your leave days and the tracker adjusts your expected output — no more flat monthly targets.
      </p>
    </div>

    <div class="rounded-xl bg-base-200 border border-base-300 px-5 py-4">
      <div class="text-xl mb-2">📈</div>
      <p class="text-sm font-semibold text-base-content/80 mb-1">Real-time view</p>
      <p class="text-xs text-base-content/45 leading-relaxed">
        Cumulated production, predicted productivity, and YTD score recalculate every time you log an action.
      </p>
    </div>

    <div class="rounded-xl bg-base-200 border border-base-300 px-5 py-4">
      <div class="text-xl mb-2">🔒</div>
      <p class="text-sm font-semibold text-base-content/80 mb-1">Fully offline</p>
      <p class="text-xs text-base-content/45 leading-relaxed">
        Your data never leaves your machine. No login, no cloud sync, no account needed.
      </p>
    </div>

  </div>

  <!-- ─── Screenshot ──────────────────────────────────── -->
  <div class="mt-8 animate-fade-in-up" style="animation-delay: 200ms;">
    <p class="text-xs font-bold uppercase tracking-widest text-base-content/30 mb-3">Preview</p>
    <div class="rounded-xl overflow-hidden border border-base-300 shadow-xl shadow-black/30">
      <img
        src="/images/excel-screenshot.png"
        alt="Screenshot of the EPO Examiner Tracker spreadsheet showing the production tracking table and charts"
        class="w-full block"
        loading="lazy"
      />
    </div>
  </div>

  <!-- ─── How to use ──────────────────────────────────── -->
  <div class="mt-8 animate-fade-in-up" style="animation-delay: 260ms;">
    <p class="text-xs font-bold uppercase tracking-widest text-base-content/30 mb-4">How to use</p>
    <ol class="flex flex-col gap-3">
      {[
        ['Download', 'Click the button above and open the file in Microsoft Excel.'],
        ['Configure', 'Set your yearly production goal, location, and enter your planned vacation days in the settings row.'],
        ['Log actions', 'Each day, add your completed actions (Research, Exam, 1st Communication…) to the tracking table.'],
        ['Check the dashboard', 'The Results panel updates automatically — compare your cumulated production against the adjusted objective.'],
      ].map(([step, desc], i) => (
        <li class="flex items-start gap-4">
          <span class="shrink-0 w-6 h-6 rounded-full bg-violet-500/15 border border-violet-500/25 flex items-center justify-center text-xs font-bold text-violet-400">
            {i + 1}
          </span>
          <p class="text-sm text-base-content/60 leading-relaxed pt-0.5">
            <span class="text-base-content/80 font-semibold">{step} — </span>{desc}
          </p>
        </li>
      ))}
    </ol>
  </div>

  <!-- ─── Bottom CTA ──────────────────────────────────── -->
  <div class="mt-10 pt-8 border-t border-base-300 flex flex-col sm:flex-row items-center justify-between gap-4 animate-fade-in-up" style="animation-delay: 300ms;">
    <p class="text-xs text-base-content/30 text-center sm:text-left">
      Your files never leave your device. &nbsp;·&nbsp; Compatible with Microsoft Excel 2016 and later.
    </p>
    <a
      href="/documents/EPO%20Pervisional%20Production.xlsx"
      download="EPO Pervisional Production.xlsx"
      class="inline-flex items-center gap-2 btn btn-primary btn-sm shrink-0"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 4v11"/>
      </svg>
      Download
    </a>
  </div>

</BaseLayout>
