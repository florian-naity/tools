---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="QR Code Reader — Decode QR Codes from Images, Free"
  description="Upload an image and instantly extract the text or URL encoded in a QR code. Free and runs entirely in your browser — no account needed."
>
  <!-- ─── Header ───────────────────────────────────────── -->
  <div class="mb-10 animate-fade-in-up">
    <a href="/" class="back-link">All Tools</a>
    <div class="mt-4 flex items-start gap-4">
      <div class="shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center text-2xl bg-primary/10 border border-primary/25 shadow-lg shadow-primary/5">
        🔍
      </div>
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-primary mb-1">QR Code</p>
        <h1 class="text-2xl font-bold leading-tight">QR Code Reader</h1>
        <p class="text-sm text-base-content/55 mt-1 max-w-md">
          Upload any image containing a QR code — the text encoded inside will be extracted instantly. Your files never leave your device.
        </p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <!-- Upload panel -->
    <div class="animate-fade-in-up" style="animation-delay: 80ms;">
      <p class="text-xs font-bold uppercase tracking-widest text-base-content/30 mb-3">Upload</p>
      <div class="relative rounded-2xl bg-base-200 border border-primary/20 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-transparent pointer-events-none"></div>
        <div class="relative p-5 flex flex-col gap-4">
          <label
            id="drop-zone"
            class="flex flex-col items-center justify-center gap-3 border-2 border-dashed border-base-300 hover:border-primary/50 rounded-xl p-8 cursor-pointer transition-colors"
          >
            <span class="text-4xl">📁</span>
            <span class="text-sm text-base-content/60 text-center">
              Click to upload or drag & drop<br/>
              <span class="text-xs text-base-content/30">PNG, JPG, GIF, WebP</span>
            </span>
            <input id="qr-file" type="file" accept="image/*" class="hidden" />
          </label>

          <div id="preview-container" class="hidden flex flex-col items-center gap-2">
            <img id="preview-img" src="" alt="Uploaded image" class="max-h-48 rounded-lg border border-base-300 object-contain" />
            <button id="clear-btn" class="btn btn-ghost btn-xs text-base-content/40">Clear</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Result panel -->
    <div class="animate-fade-in-up" style="animation-delay: 120ms;">
      <p class="text-xs font-bold uppercase tracking-widest text-base-content/30 mb-3">Result</p>
      <div class="rounded-2xl bg-base-200 border border-primary/20 p-6 flex flex-col gap-4 justify-center min-h-48">
        <div id="result-placeholder" class="text-sm text-base-content/30 text-center">
          Upload an image to decode it.
        </div>

        <div id="result-content" class="hidden flex flex-col gap-3">
          <label class="text-xs font-semibold uppercase tracking-widest text-primary/60">Decoded Text</label>
          <div
            id="result-text"
            class="bg-base-100 border border-base-300 rounded-lg p-3 text-sm font-mono break-all text-base-content min-h-16"
          ></div>
          <div class="flex gap-2">
            <button id="copy-btn" class="btn btn-primary btn-sm flex-1">Copy to Clipboard</button>
            <a id="open-link" href="#" target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm hidden">Open URL ↗</a>
          </div>
          <p id="copy-confirm" class="hidden text-xs text-success text-center">Copied!</p>
        </div>

        <div id="result-error" class="hidden flex flex-col items-center gap-2">
          <span class="text-2xl">❌</span>
          <p class="text-sm text-error text-center">No QR code found in this image.</p>
          <p class="text-xs text-base-content/40 text-center">Make sure the QR code is clearly visible and not too blurry.</p>
        </div>
      </div>
    </div>

  </div>

  <!-- Hidden canvas for pixel extraction -->
  <canvas id="decode-canvas" class="hidden"></canvas>

  <div class="mt-10 pt-6 border-t border-base-300 flex flex-col sm:flex-row items-center justify-between gap-2">
    <p class="text-xs text-base-content/30">Your files never leave your device.</p>
    <p class="text-xs text-base-content/25">Powered by <a href="https://github.com/cozmo/jsQR" class="underline hover:text-primary transition-colors" target="_blank" rel="noopener">jsQR</a> by Cosmo Wolfe (MIT).</p>
  </div>
  <!-- ─── How it works + FAQ ──────────────────────────────── -->
  <div class="mt-16 flex flex-col gap-10 border-t border-base-300 pt-10">

    <section>
      <p class="text-xs font-bold uppercase tracking-widest text-primary mb-5">How it works</p>
      <ol class="flex flex-col gap-4">
        <li class="flex gap-3 items-start">
          <span class="shrink-0 w-6 h-6 rounded-full bg-primary/15 border border-primary/25 text-xs font-bold text-primary flex items-center justify-center mt-0.5">1</span>
          <p class="text-sm text-base-content/70 leading-relaxed">Upload an image containing a QR code (PNG, JPG, WebP, or GIF).</p>
        </li>
        <li class="flex gap-3 items-start">
          <span class="shrink-0 w-6 h-6 rounded-full bg-primary/15 border border-primary/25 text-xs font-bold text-primary flex items-center justify-center mt-0.5">2</span>
          <p class="text-sm text-base-content/70 leading-relaxed">The decoder scans the image instantly and extracts the encoded text — no server involved.</p>
        </li>
        <li class="flex gap-3 items-start">
          <span class="shrink-0 w-6 h-6 rounded-full bg-primary/15 border border-primary/25 text-xs font-bold text-primary flex items-center justify-center mt-0.5">3</span>
          <p class="text-sm text-base-content/70 leading-relaxed">Copy the result or, if it's a URL, open it directly from the result panel.</p>
        </li>
      </ol>
    </section>

    <section>
      <p class="text-xs font-bold uppercase tracking-widest text-primary mb-4">Frequently asked questions</p>
      <div class="flex flex-col divide-y divide-base-300">
        <details class="py-4 group">
          <summary class="cursor-pointer list-none text-sm font-semibold text-base-content/80 flex justify-between items-center gap-4">
            What image formats are supported?
            <span class="group-open:rotate-180 transition-transform shrink-0 text-base-content/30 text-xs">▾</span>
          </summary>
          <p class="mt-3 text-sm text-base-content/55 leading-relaxed">PNG, JPG, WebP, and GIF. The QR code must be clearly visible and not too small or heavily distorted.</p>
        </details>
        <details class="py-4 group">
          <summary class="cursor-pointer list-none text-sm font-semibold text-base-content/80 flex justify-between items-center gap-4">
            Can it read QR codes from screenshots?
            <span class="group-open:rotate-180 transition-transform shrink-0 text-base-content/30 text-xs">▾</span>
          </summary>
          <p class="mt-3 text-sm text-base-content/55 leading-relaxed">Yes — upload a screenshot directly and the decoder will locate and decode the QR code within it.</p>
        </details>
        <details class="py-4 group">
          <summary class="cursor-pointer list-none text-sm font-semibold text-base-content/80 flex justify-between items-center gap-4">
            Does it work offline?
            <span class="group-open:rotate-180 transition-transform shrink-0 text-base-content/30 text-xs">▾</span>
          </summary>
          <p class="mt-3 text-sm text-base-content/55 leading-relaxed">Yes. Once the page is loaded, decoding runs locally with no internet connection required.</p>
        </details>
        <details class="py-4 group">
          <summary class="cursor-pointer list-none text-sm font-semibold text-base-content/80 flex justify-between items-center gap-4">
            What if my QR code is not detected?
            <span class="group-open:rotate-180 transition-transform shrink-0 text-base-content/30 text-xs">▾</span>
          </summary>
          <p class="mt-3 text-sm text-base-content/55 leading-relaxed">Make sure the QR code is sharp and fills a reasonable portion of the image. Cropping the image closer to the QR code before uploading usually helps.</p>
        </details>
      </div>
    </section>

  </div>

  <script is:inline type="application/ld+json">{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What image formats are supported?", "acceptedAnswer": { "@type": "Answer", "text": "PNG, JPG, WebP, and GIF. The QR code must be clearly visible and not too small or heavily distorted." } },
      { "@type": "Question", "name": "Can it read QR codes from screenshots?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — upload a screenshot directly and the decoder will locate and decode the QR code within it." } },
      { "@type": "Question", "name": "Does it work offline?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Once the page is loaded, decoding runs locally with no internet connection required." } },
      { "@type": "Question", "name": "What if my QR code is not detected?", "acceptedAnswer": { "@type": "Answer", "text": "Make sure the QR code is sharp and fills a reasonable portion of the image. Cropping the image closer to the QR code before uploading usually helps." } }
    ]
  }</script>

</BaseLayout>

<script>
  const fileInput = document.getElementById('qr-file') as HTMLInputElement;
  const dropZone = document.getElementById('drop-zone') as HTMLLabelElement;
  const previewContainer = document.getElementById('preview-container') as HTMLDivElement;
  const previewImg = document.getElementById('preview-img') as HTMLImageElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const canvas = document.getElementById('decode-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  const resultPlaceholder = document.getElementById('result-placeholder') as HTMLDivElement;
  const resultContent = document.getElementById('result-content') as HTMLDivElement;
  const resultText = document.getElementById('result-text') as HTMLDivElement;
  const resultError = document.getElementById('result-error') as HTMLDivElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const copyConfirm = document.getElementById('copy-confirm') as HTMLParagraphElement;
  const openLink = document.getElementById('open-link') as HTMLAnchorElement;

  function resetResult() {
    resultPlaceholder.classList.remove('hidden');
    resultContent.classList.add('hidden');
    resultError.classList.add('hidden');
  }

  function decodeImage(file: File) {
    const url = URL.createObjectURL(file);
    const img = new Image();
    img.onload = () => {
      canvas.width = img.width;
      canvas.height = img.height;
      ctx.drawImage(img, 0, 0);
      const imageData = ctx.getImageData(0, 0, img.width, img.height);
      URL.revokeObjectURL(url);

      // @ts-ignore — loaded from public/vendor/jsQR.js
      const result = jsQR(imageData.data, imageData.width, imageData.height);

      resultPlaceholder.classList.add('hidden');
      if (result) {
        resultText.textContent = result.data;
        resultContent.classList.remove('hidden');
        resultError.classList.add('hidden');

        // Show "Open URL" button if it looks like a URL
        try {
          new URL(result.data);
          openLink.href = result.data;
          openLink.classList.remove('hidden');
        } catch {
          openLink.classList.add('hidden');
        }
      } else {
        resultContent.classList.add('hidden');
        resultError.classList.remove('hidden');
      }
    };
    img.src = url;
  }

  function handleFile(file: File) {
    if (!file.type.startsWith('image/')) return;
    previewImg.src = URL.createObjectURL(file);
    previewContainer.classList.remove('hidden');
    decodeImage(file);
  }

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.[0]) handleFile(fileInput.files[0]);
  });

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-primary');
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-primary');
  });
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-primary');
    const file = e.dataTransfer?.files[0];
    if (file) handleFile(file);
  });

  clearBtn.addEventListener('click', () => {
    fileInput.value = '';
    previewImg.src = '';
    previewContainer.classList.add('hidden');
    resetResult();
  });

  copyBtn.addEventListener('click', async () => {
    await navigator.clipboard.writeText(resultText.textContent ?? '');
    copyConfirm.classList.remove('hidden');
    setTimeout(() => copyConfirm.classList.add('hidden'), 2000);
  });
</script>

<script src="/vendor/jsQR.js" is:inline></script>
