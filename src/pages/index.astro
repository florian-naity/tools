---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';

type Tool = { title: string; description: string; href: string; icon: string; badge?: string };
type Group = { label: string; accent: string; labelColor: string; accentHex: string; tools: Tool[] };

const groups: Group[] = [
  {
    label: 'PDF',
    accent: 'border-orange-500/30',
    labelColor: 'text-orange-400',
    accentHex: '#fb923c',
    tools: [
      {
        title: 'Images to PDF',
        description: 'Combine images into a single PDF. Drag to reorder, choose page size.',
        href: '/images-to-pdf',
        icon: '🖼️',
      },
      {
        title: 'PDF to Images',
        description: 'Export each page of a PDF as PNG or JPG, downloaded as a ZIP.',
        href: '/pdf-to-images',
        icon: '📄',
      },
      {
        title: 'Reorder & Delete Pages',
        description: 'Drag pages to reorder or remove them, then save the result.',
        href: '/reorder-pdf',
        icon: '✂️',
      },
      {
        title: 'Merge PDFs',
        description: 'Combine multiple PDF files into one, in the order you choose.',
        href: '/merge-pdf',
        icon: '📎',
      },
      {
        title: 'PDF Text Extractor',
        description: 'Extract all readable text from a PDF. Copy it, download as a clean PDF or Markdown.',
        href: '/pdf-text-extractor',
        icon: '🔤',
      },
    ],
  },
  {
    label: 'QR Code',
    accent: 'border-primary/30',
    labelColor: 'text-primary',
    accentHex: '#f59e0b',
    tools: [
      {
        title: 'QR Code Generator',
        description: 'Generate a customizable QR code from any text or URL.',
        href: '/qr-generator',
        icon: '⬛',
      },
      {
        title: 'QR Code Reader',
        description: 'Upload an image containing a QR code and extract the encoded text.',
        href: '/qr-reader',
        icon: '🔍',
      },
    ],
  },
  {
    label: 'Productivity',
    accent: 'border-violet-500/30',
    labelColor: 'text-violet-400',
    accentHex: '#a78bfa',
    tools: [
      {
        title: 'Offline Examiner Tracker',
        description: 'Track productivity offline in a local Excel file. Takes vacancies into account to view if you are on track.',
        href: '/offline-examiner-tracker',
        icon: '📗',
      },
      {
        title: 'Online Examiner Tracker',
        description: 'Track productivity and goals as a patent examiner. Data saved to your Google Drive.',
        href: '/examiner-tracker',
        icon: '🎯',
        badge: 'coming soon',
      },
    ],
  },
  {
    label: 'Markdown',
    accent: 'border-sky-500/30',
    labelColor: 'text-sky-400',
    accentHex: '#38bdf8',
    tools: [
      {
        title: 'Document to Markdown',
        description: 'Convert PDFs, Word docs, and web pages to clean Markdown — ideal for AI workflows and Obsidian vaults.',
        href: '/document-to-markdown',
        icon: '📄',
      },
      {
        title: 'Markdown Editor',
        description: 'Paste rich text and get Markdown instantly, or write Markdown and copy formatted HTML.',
        href: '/markdown-editor',
        icon: '✍️',
      },
    ],
  },
];

const totalTools = groups.reduce((n, g) => n + g.tools.filter(t => !t.badge).length, 0);
---

<BaseLayout title="Free Browser Tools" description="Free, private browser tools for PDF editing, QR codes, and Markdown. Everything runs in your browser — no uploads, no accounts, no trackers.">

  <!-- ─── Hero ─────────────────────────────────────── -->
  <div class="mb-14 animate-fade-in-up">

    <!-- Status pill -->
    <div class="inline-flex items-center gap-2 mb-5 px-3 py-1.5 rounded-full bg-base-200 border border-base-300 text-xs text-base-content/50 select-none">
      <span class="w-1.5 h-1.5 rounded-full bg-primary animate-soft-pulse"></span>
      <span>{totalTools} tools · runs entirely in your browser</span>
    </div>

    <h1 class="text-4xl sm:text-5xl font-bold leading-[1.15] tracking-tight">
      <span class="text-base-content">Small tools,</span><br/>
      <span class="hero-gradient">big convenience.</span>
    </h1>

    <p class="mt-4 text-base-content/55 text-sm max-w-md leading-relaxed">
      Focused browser utilities for everyday tasks —
      no uploads, no accounts, no trackers. Everything stays on your device.
    </p>
  </div>

  <!-- ─── Tool groups ───────────────────────────────── -->
  <div class="flex flex-col gap-12">
    {groups.map((group, gi) => (
      <section class="animate-fade-in-up" style={`animation-delay: ${100 + gi * 60}ms;`}>

        <!-- Section label + gradient divider -->
        <div class="flex items-center gap-3 mb-5">
          <span
            class="text-xs font-bold uppercase tracking-widest shrink-0"
            style={`color: ${group.accentHex};`}
          >
            {group.label}
          </span>
          <div
            class="flex-1 h-px"
            style={`background: linear-gradient(to right, ${group.accentHex}55, transparent);`}
          ></div>
        </div>

        <!-- Cards grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {group.tools.map((tool, i) => (
            <div class="animate-fade-in-up" style={`animation-delay: ${160 + gi * 60 + i * 70}ms;`}>
              <ToolCard {...tool} accentColor={group.accentHex} />
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>

</BaseLayout>

<style>
  .hero-gradient {
    background: linear-gradient(135deg, #fbbf24 0%, #fb923c 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
