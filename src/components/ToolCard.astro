---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  badge?: string;
  accentColor?: string;
}

const { title, description, href, icon, badge, accentColor = '#f59e0b' } = Astro.props;
const isSoon = badge === 'coming soon';
---

<a
  href={href}
  class={`tool-card ${isSoon ? 'is-soon' : ''}`}
  style={`--card-accent: ${accentColor};`}
  aria-disabled={isSoon ? 'true' : undefined}
  tabindex={isSoon ? -1 : undefined}
>
  <!-- Left accent bar that scales in on hover -->
  <div class="card-left-bar"></div>

  <!-- Icon row -->
  <div class="card-top">
    <div class="card-icon-wrap">
      {icon}
    </div>
    <div class="card-top-right">
      {isSoon ? (
        <span class="badge-soon">soon</span>
      ) : (
        <svg class="card-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      )}
    </div>
  </div>

  <!-- Text -->
  <div>
    <h2 class="card-title">{title}</h2>
    <p class="card-description">{description}</p>
  </div>
</a>

<style>
  .tool-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--color-base-200);
    border: 1px solid var(--color-base-300);
    border-radius: var(--radius-box);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    height: 100%;
  }

  .tool-card:not(.is-soon):hover {
    border-color: color-mix(in srgb, var(--card-accent) 45%, transparent);
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.35),
      0 0 0 1px color-mix(in srgb, var(--card-accent) 15%, transparent),
      inset 0 1px 0 color-mix(in srgb, var(--card-accent) 8%, transparent);
    transform: translateY(-2px);
  }

  .is-soon {
    opacity: 0.5;
    cursor: default;
    pointer-events: none;
  }

  /* Left accent bar */
  .card-left-bar {
    position: absolute;
    left: 0;
    top: 18%;
    bottom: 18%;
    width: 2px;
    border-radius: 0 2px 2px 0;
    background: var(--card-accent);
    transform: scaleY(0);
    transform-origin: center;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .tool-card:not(.is-soon):hover .card-left-bar {
    transform: scaleY(1);
  }

  /* Icon wrapper */
  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-icon-wrap {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.375rem;
    flex-shrink: 0;
    background: color-mix(in srgb, var(--card-accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-accent) 20%, transparent);
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .tool-card:not(.is-soon):hover .card-icon-wrap {
    transform: scale(1.1) rotate(-4deg);
  }

  .card-top-right {
    margin-top: 0.125rem;
    flex-shrink: 0;
  }

  /* Arrow */
  .card-arrow {
    width: 1rem;
    height: 1rem;
    color: var(--card-accent);
    opacity: 0;
    transform: translateX(-5px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .tool-card:not(.is-soon):hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* "soon" badge */
  .badge-soon {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.55rem;
    border-radius: 9999px;
    border: 1px solid var(--color-base-300);
    color: color-mix(in srgb, var(--color-base-content) 30%, transparent);
  }

  /* Text */
  .card-title {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-base-content);
    transition: color 0.2s ease;
    line-height: 1.4;
  }

  .tool-card:not(.is-soon):hover .card-title {
    color: var(--card-accent);
  }

  .card-description {
    font-size: 0.8125rem;
    color: color-mix(in srgb, var(--color-base-content) 52%, transparent);
    margin-top: 0.375rem;
    line-height: 1.65;
  }
</style>
