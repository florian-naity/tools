---
const navLinks = [
  { href: '/', label: 'All Tools' },
];
---

<div class="navbar bg-base-200 border-b border-base-300 px-6 sticky top-0 z-50 relative">
  <div class="w-full max-w-4xl mx-auto flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-primary font-bold text-lg tracking-tight group-hover:text-accent transition-colors">
        tools<span class="text-base-content/40">.</span>florianabry<span class="text-base-content/40">.</span>me
      </span>
    </a>
    <nav class="flex items-center gap-4">
      {navLinks.map(link => (
        <a href={link.href} class="text-sm text-base-content/70 hover:text-primary transition-colors font-medium">
          {link.label}
        </a>
      ))}
      <a
        href="https://florianabry.me"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-base-content/40 hover:text-base-content/70 transition-colors"
      >
        florianabry.me ↗
      </a>
    </nav>
  </div>
</div>
