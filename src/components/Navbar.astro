---
const groups = [
  {
    label: 'PDF',
    color: 'text-orange-400',
    tools: [
      { href: '/images-to-pdf', label: 'Images to PDF', icon: '🖼️', soon: false },
      { href: '/pdf-to-images', label: 'PDF to Images', icon: '📄', soon: false },
      { href: '/reorder-pdf',   label: 'Reorder & Delete Pages', icon: '✂️', soon: false },
      { href: '/merge-pdf',     label: 'Merge PDFs', icon: '📎', soon: false },
    ],
  },
  {
    label: 'QR Code',
    color: 'text-primary',
    tools: [
      { href: '/qr-generator', label: 'QR Generator', icon: '⬛', soon: false },
      { href: '/qr-reader',    label: 'QR Reader', icon: '🔍', soon: false },
    ],
  },
  {
    label: 'Spreadsheets',
    color: 'text-emerald-400',
    tools: [
      { href: '/excel-editor',  label: 'Excel Viewer / Editor', icon: '📊', soon: true },
      { href: '/excel-to-csv',  label: 'Excel to CSV', icon: '📋', soon: true },
    ],
  },
  {
    label: 'Productivity',
    color: 'text-violet-400',
    tools: [
      { href: '/examiner-tracker', label: 'Examiner Tracker', icon: '🎯', soon: true },
    ],
  },
];
---

<div class="sticky top-0 z-50">
<div class="navbar bg-base-200 border-b border-base-300">
  <div class="w-full max-w-4xl mx-auto flex items-center justify-between px-6">

    <!-- Left: Home -->
    <a href="/" class="flex items-center gap-2 group shrink-0">
      <span class="text-primary font-bold text-base tracking-tight group-hover:text-accent transition-colors">
        tools<span class="text-base-content/30">.</span>florianabry<span class="text-base-content/30">.</span>me
      </span>
    </a>

    <!-- Center: category dropdowns (desktop) -->
    <nav id="desktop-nav" class="hidden md:flex items-center gap-1">
      {groups.map(group => (
        <div class="relative group/menu">
          <button class={`flex items-center gap-1 px-3 py-2 text-sm font-medium text-base-content/60 hover:text-base-content transition-colors rounded-lg hover:bg-base-300`}>
            {group.label}
            <svg class="w-3 h-3 opacity-50 group-hover/menu:opacity-100 transition-transform group-hover/menu:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <!-- Dropdown -->
          <div class="absolute left-0 top-full mt-1 w-52 bg-base-200 border border-base-300 rounded-xl shadow-xl opacity-0 invisible group-hover/menu:opacity-100 group-hover/menu:visible transition-all duration-150 z-50 py-1">
            <p class={`px-3 pt-2 pb-1 text-xs font-bold uppercase tracking-widest ${group.color}`}>{group.label}</p>
            {group.tools.map(tool => (
              <a
                href={tool.href}
                class="flex items-center gap-2.5 px-3 py-2 text-sm text-base-content/70 hover:text-base-content hover:bg-base-300 transition-colors mx-1 rounded-lg"
              >
                <span class="text-base leading-none">{tool.icon}</span>
                <span class="flex-1">{tool.label}</span>
                {tool.soon && <span class="text-xs text-base-content/30 shrink-0">soon</span>}
              </a>
            ))}
          </div>
        </div>
      ))}
    </nav>

    <!-- Right: personal site + mobile burger -->
    <div class="flex items-center gap-2 shrink-0">
      <a
        href="https://florianabry.me"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:block text-xs text-base-content/30 hover:text-base-content/60 transition-colors"
      >
        florianabry.me ↗
      </a>

      <!-- Mobile burger -->
      <button id="mobile-menu-btn" class="md:hidden btn btn-ghost btn-sm px-2" aria-label="Open menu">
        <svg id="icon-burger" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

  </div>

  </div><!-- /navbar -->

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-base-300 bg-base-200 w-full">
    <div class="max-w-4xl mx-auto px-6 py-3 flex flex-col gap-4">
      {groups.map(group => (
        <div>
          <p class={`text-xs font-bold uppercase tracking-widest mb-1 ${group.color}`}>{group.label}</p>
          <div class="flex flex-col">
            {group.tools.map(tool => (
              <a
                href={tool.href}
                class="mobile-nav-link flex items-center gap-2.5 py-2 text-sm text-base-content/70 hover:text-base-content transition-colors"
              >
                <span>{tool.icon}</span>
                <span class="flex-1">{tool.label}</span>
                {tool.soon && <span class="text-xs text-base-content/30">soon</span>}
              </a>
            ))}
          </div>
        </div>
      ))}
      <a
        href="https://florianabry.me"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs text-base-content/30 hover:text-base-content/60 transition-colors pb-2"
      >
        florianabry.me ↗
      </a>
    </div>
  </div>

</div>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconBurger = document.getElementById('icon-burger')!;
  const iconClose = document.getElementById('icon-close')!;

  btn.addEventListener('click', () => {
    const open = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', open);
    iconBurger.classList.toggle('hidden', !open);
    iconClose.classList.toggle('hidden', open);
  });

  // Close mobile menu when a link is clicked
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconBurger.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
