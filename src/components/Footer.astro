    <div class="flex items-center gap-3">
      <span>© {year} <a href="https://florianabry.me" class="hover:text-primary transition-colors">Florian Abry</a></span>
      <span class="text-base-content/20">·</span>
      <a href="/legal" class="hover:text-primary transition-colors">Legal notice</a>
      <span class="text-base-content/20">·</span>
      <a href="/datenschutz" class="hover:text-primary transition-colors">Privacy policy</a>
    </div>
    <span>All tools run locally in your browser — your files never leave your device.</span>
  </div>
</footer>
