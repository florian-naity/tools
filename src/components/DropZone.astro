---
interface Props {
  id: string;
  accept: string;
  multiple?: boolean;
  label?: string;
}

const { id, accept, multiple = false, label = 'Click to upload or drag & drop' } = Astro.props;

const acceptLabel = accept === 'application/pdf'
  ? 'PDF files'
  : accept === 'image/*'
  ? 'PNG, JPG, WebP, GIF'
  : accept;
---

<div
  class="dropzone-root flex flex-col items-center justify-center gap-3 border-2 border-dashed border-base-300 hover:border-primary/50 rounded-lg p-8 cursor-pointer transition-colors"
  data-id={id}
>
  <span class="text-4xl pointer-events-none select-none">📁</span>
  <span class="text-sm text-base-content/60 text-center pointer-events-none">
    {label}<br/>
    <span class="text-xs text-base-content/30">{acceptLabel}</span>
  </span>
  <input
    id={id}
    type="file"
    accept={accept}
    multiple={multiple}
    class="hidden"
  />
</div>

<script>
  function initDropZones() {
    document.querySelectorAll<HTMLDivElement>('.dropzone-root').forEach(zone => {
      const id = zone.dataset.id!;
      const fileInput = document.getElementById(id) as HTMLInputElement;

      zone.addEventListener('click', () => fileInput.click());

      zone.addEventListener('dragover', (e) => {
        e.preventDefault();
        zone.classList.add('border-primary', 'bg-base-300/30');
      });

      zone.addEventListener('dragleave', () => {
        zone.classList.remove('border-primary', 'bg-base-300/30');
      });

      zone.addEventListener('drop', (e: DragEvent) => {
        e.preventDefault();
        zone.classList.remove('border-primary', 'bg-base-300/30');
        const files = e.dataTransfer?.files;
        if (files?.length) {
          zone.dispatchEvent(new CustomEvent('dropzone:files', { detail: files, bubbles: true }));
        }
      });

      fileInput.addEventListener('change', () => {
        if (fileInput.files?.length) {
          zone.dispatchEvent(new CustomEvent('dropzone:files', { detail: fileInput.files, bubbles: true }));
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initDropZones);
</script>
